    "TICKET_ID",
    "TICKET_CLASS",
    "STOP_CODE",
    "STATE_FINGERPRINT",
    "STATE_DELTA",
    "RETRY_SERIES_ID",
    "RETRY_INDEX",
    "LOOP_DECISION",
    "NEXT_ROUTE",
    "RESUME_CONDITION"
  ],
  "decisionGate": "if loopDecision != CONTINUE then READY_FOR_EXEC is forbidden"
}
