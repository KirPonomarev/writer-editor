{
  "version": "v2",
  "fonts": [
    {
      "id": "font-palatino",
      "label": "Palatino",
      "value": "Palatino, 'Palatino Linotype', 'Book Antiqua', serif"
    },
    {
      "id": "font-georgia",
      "label": "Georgia",
      "value": "Georgia, serif"
    }
  ],
  "menus": [
    {
      "id": "file",
      "label": "Документ",
      "labelKey": "menu.file",
      "mode": ["offline"],
      "profile": ["minimal", "pro", "guru"],
      "stage": ["X1", "X2", "X3", "X4"],
      "enabledWhen": {
        "op": "all",
        "args": []
      },
      "items": [
        {
          "id": "file-open",
          "label": "Открыть проект...",
          "labelKey": "menu.file.open",
          "accelerator": "CmdOrCtrl+O",
          "actionId": "openDocument",
          "mode": ["offline"],
          "profile": ["minimal", "pro", "guru"],
          "stage": ["X1", "X2", "X3", "X4"],
          "enabledWhen": {
            "op": "all",
            "args": []
          }
        },
        {
          "id": "file-save",
          "label": "Сохранить",
          "labelKey": "menu.file.save",
          "accelerator": "CmdOrCtrl+S",
          "actionId": "saveDocument",
          "mode": ["offline"],
          "profile": ["minimal", "pro", "guru"],
          "stage": ["X1", "X2", "X3", "X4"],
          "enabledWhen": {
            "op": "flag",
            "name": "hasDocument"
          }
        },
        {
          "id": "file-export-docx",
          "label": "Экспорт DOCX",
          "labelKey": "menu.file.exportDocx",
          "actionId": "exportDocxMin",
          "mode": ["offline"],
          "profile": ["pro", "guru"],
          "stage": ["X1", "X2", "X3", "X4"],
          "enabledWhen": {
            "op": "flag",
            "name": "hasDocument"
          }
        }
      ]
    },
    {
      "id": "edit",
      "label": "Редактирование",
      "labelKey": "menu.edit",
      "items": [
        {
          "id": "edit-copy",
          "role": "copy",
          "mode": ["offline", "web_subset"],
          "profile": ["minimal", "pro", "guru"],
          "stage": ["X1", "X2", "X3", "X4"],
          "enabledWhen": {
            "op": "flag",
            "name": "selectionExists"
          }
        }
      ]
    },
    {
      "id": "view",
      "label": "View",
      "labelKey": "menu.view",
      "items": [
        {
          "id": "view-settings",
          "label": "Settings",
          "labelKey": "menu.view.settings",
          "command": "cmd.project.view.openSettings"
        },
        {
          "id": "view-presentation-mode",
          "label": "Presentation Mode",
          "labelKey": "menu.view.presentation",
          "items": [
            {
              "id": "view-presentation-classic",
              "label": "Classic",
              "labelKey": "menu.view.presentation.classic",
              "command": "cmd.project.view.setMenuPresentationClassic"
            },
            {
              "id": "view-presentation-compact",
              "label": "Compact",
              "labelKey": "menu.view.presentation.compact",
              "command": "cmd.project.view.setMenuPresentationCompact"
            }
          ]
        },
        {
          "id": "view-language",
          "label": "Language",
          "labelKey": "menu.view.language",
          "items": [
            {
              "id": "view-language-base",
              "label": "Base",
              "labelKey": "menu.view.language.base",
              "command": "cmd.project.view.setMenuLocaleBase"
            },
            {
              "id": "view-language-ru",
              "label": "Русский",
              "labelKey": "menu.view.language.ru",
              "command": "cmd.project.view.setMenuLocaleRu"
            },
            {
              "id": "view-language-en",
              "label": "English",
              "labelKey": "menu.view.language.en",
              "command": "cmd.project.view.setMenuLocaleEn"
            }
          ]
        },
        {
          "id": "view-menu-customization",
          "label": "Menu Customization",
          "labelKey": "menu.view.customization",
          "items": [
            {
              "id": "view-menu-customization-visibility",
              "label": "Visibility",
              "labelKey": "menu.view.customization.visibility",
              "submenuFrom": "menuCustomizationVisibilitySections"
            },
            {
              "id": "view-menu-customization-order",
              "label": "Order",
              "labelKey": "menu.view.customization.order",
              "submenuFrom": "menuCustomizationOrderSections"
            },
            {
              "id": "view-menu-customization-reset",
              "label": "Reset Menu Customization",
              "labelKey": "menu.view.customization.reset",
              "command": "cmd.project.view.resetMenuCustomization"
            }
          ]
        },
        {
          "id": "view-safe-reset",
          "label": "Safe Reset",
          "labelKey": "menu.view.safeReset",
          "command": "cmd.project.view.safeReset"
        },
        {
          "id": "view-restore-last-stable",
          "label": "Restore Last Stable",
          "labelKey": "menu.view.restoreLastStable",
          "command": "cmd.project.view.restoreLastStable"
        },
        {
          "id": "view-switch-write",
          "label": "Write Mode",
          "labelKey": "menu.view.mode.write",
          "command": "cmd.project.window.switchModeWrite"
        },
        {
          "id": "view-switch-plan",
          "label": "Plan Mode",
          "labelKey": "menu.view.mode.plan",
          "command": "cmd.project.plan.switchMode"
        },
        {
          "id": "view-switch-review",
          "label": "Review Mode",
          "labelKey": "menu.view.mode.review",
          "command": "cmd.project.review.switchMode"
        }
      ]
    },
    {
      "id": "insert",
      "label": "Insert",
      "labelKey": "menu.insert",
      "items": [
        {
          "id": "insert-add-card",
          "label": "Add Card",
          "labelKey": "menu.insert.addCard",
          "command": "cmd.project.insert.addCard"
        }
      ]
    },
    {
      "id": "format",
      "label": "Format",
      "labelKey": "menu.format",
      "items": [
        {
          "id": "format-align-left",
          "label": "Align Left",
          "labelKey": "menu.format.alignLeft",
          "command": "cmd.project.format.alignLeft"
        }
      ]
    },
    {
      "id": "plan",
      "label": "Plan",
      "labelKey": "menu.plan",
      "items": [
        {
          "id": "plan-mode",
          "label": "Open Plan Mode",
          "labelKey": "menu.plan.openMode",
          "command": "cmd.project.plan.switchMode"
        }
      ]
    },
    {
      "id": "review",
      "label": "Review",
      "labelKey": "menu.review",
      "items": [
        {
          "id": "review-mode",
          "label": "Open Review Mode",
          "labelKey": "menu.review.openMode",
          "command": "cmd.project.review.switchMode"
        },
        {
          "id": "review-recovery",
          "label": "Recovery",
          "labelKey": "menu.review.recovery",
          "command": "cmd.project.review.openRecovery"
        }
      ]
    },
    {
      "id": "tools",
      "label": "Tools",
      "labelKey": "menu.tools",
      "items": [
        {
          "id": "tools-diagnostics",
          "label": "Diagnostics",
          "labelKey": "menu.tools.diagnostics",
          "command": "cmd.project.tools.openDiagnostics"
        }
      ]
    },
    {
      "id": "window",
      "label": "Window",
      "labelKey": "menu.window",
      "items": [
        {
          "id": "window-write-mode",
          "label": "Back To Write Mode",
          "labelKey": "menu.window.backToWrite",
          "command": "cmd.project.window.switchModeWrite"
        }
      ]
    },
    {
      "id": "help",
      "label": "Help",
      "labelKey": "menu.help",
      "items": []
    }
  ]
}
